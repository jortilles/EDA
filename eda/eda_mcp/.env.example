# URL interna de la EDA API (sin trailing slash)
EDA_API_URL=http://localhost:8888

# Puerto en el que escucha el MCP server
PORT=3100

# Credenciales de auto-login (opcionales)
# Si se configuran, el tool list_dashboards no requiere que el cliente pase un token
EDA_EMAIL=admin@example.com
EDA_PASSWORD=yourpassword
