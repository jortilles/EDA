{
    "compileOnSave": false,
    "compilerOptions": {
      "allowSyntheticDefaultImports": true,
      "baseUrl": "./src",
      "paths": {
        "@eda/components/*": ["app/module/components/*"],
        "@eda/services/*": ["app/services/*"],
        "@eda/models/*": ["app/shared/models/*"],
        "@eda/pipes/*": ["app/shared/pipes/*"],
        "@eda/shared/*": ["app/shared/*"],
        "@eda/configs/*": ["app/config/*"]
      },
      "outDir": "./dist/out-tsc",
      "sourceMap": true,
      "declaration": false,
      "moduleResolution": "bundler",
      "experimentalDecorators": true,
      "emitDecoratorMetadata": true,
      "importHelpers": true,
      "module": "es2022", // 🔄 Cambiado a "esnext" para soporte completo en Angular 17
      "target": "es2022", // ✅ Es válido, pero "esnext" podría ser una opción si planeas usar lo más reciente
      "typeRoots": ["node_modules/@types"],
      "types": ["node"],
      "lib": ["es2022", "dom"],
      "useDefineForClassFields": false,
      "strict": false,
      "strictPropertyInitialization": false
    },
    "angularCompilerOptions": {
      "strictTemplates": true,
      "strictInjectionParameters": true,
      "strictDomEventTypes": false, // Disable DOM Types
      "enableI18nLegacyMessageIdFormat": false, // ✅ Angular moderno no necesita IDs legados para i18n
      "i18nInLocale": "es-ES", // ✅ Cambia esto si quieres otro idioma predeterminado
      "i18nOutFile": "src/locale/messages.xlf", // ✅ Si deseas extraer mensajes, especifica el archivo de salida
      "i18nOutFormat": "xlf" // ✅ Especifica el formato de exportación de i18n (por defecto es "xlf")
    }
}
  