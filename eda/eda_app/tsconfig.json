{
    "compileOnSave": false,
    "compilerOptions": {
      "allowSyntheticDefaultImports": true,
      "paths": {
        "@eda/components/*": ["./src/app/module/components/*"],
        "@eda/services/*": ["./src/app/services/*"],
        "@eda/models/*": ["./src/app/shared/models/*"],
        "@eda/pipes/*": ["./src/app/shared/pipes/*"],
        "@eda/shared/*": ["./src/app/shared/*"],
        "@eda/configs/*": ["./src/app/config/*"]
      },
      "outDir": "./dist/out-tsc",
      "sourceMap": true,
      "declaration": false,
      "moduleResolution": "bundler",
      "experimentalDecorators": true,
      "emitDecoratorMetadata": true,
      "importHelpers": true,
      "module": "es2022", // Changed to "esnext" for full Angular 17 support
      "target": "es2022", // Valid; "esnext" is an option if you want the latest features
      "typeRoots": ["node_modules/@types"],
      "types": ["node"],
      "lib": ["es2022", "dom"],
      "useDefineForClassFields": false,
      "strict": false,
      "strictPropertyInitialization": false
    },
    "angularCompilerOptions": {
      "strictTemplates": true,
      "strictInjectionParameters": true,
      "strictDomEventTypes": false, // Disable DOM Types
      "enableI18nLegacyMessageIdFormat": false, // Modern Angular does not need legacy i18n message IDs
      "i18nInLocale": "es-ES", // Change this to use a different default locale
      "i18nOutFile": "src/locale/messages.xlf", // Output file for extracted i18n messages
      "i18nOutFormat": "xlf" // Export format for i18n messages (default is "xlf")
    }
}
  